# 支付宝小程序后端环境配置

# 应用配置
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_SECRET_KEY=change-this-to-another-random-secret-key-in-production
PORT=5001

# 数据库配置
# SQLite (开发环境)
DATABASE_URL=sqlite:///alipay_miniprogram.db
# PostgreSQL (生产环境)
# DATABASE_URL=postgresql://user:password@localhost/alipay_miniprogram

# 支付宝沙箱环境配置
# 沙箱应用ID
ALIPAY_APP_ID=your-sandbox-app-id
# 应用私钥（RSA2格式）
ALIPAY_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
你的私钥内容
-----END RSA PRIVATE KEY-----"
# 支付宝公钥
ALIPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
支付宝公钥内容
-----END PUBLIC KEY-----"
# 沙箱网关地址
ALIPAY_SERVER_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# 支付宝生产环境配置（部署时取消注释）
# ALIPAY_APP_ID=your-production-app-id
# ALIPAY_SERVER_URL=https://openapi.alipay.com/gateway.do

# 小程序配置
MINIPROGRAM_APP_ID=your-miniprogram-app-id
MINIPROGRAM_APP_SECRET=your-miniprogram-secret

# 芝麻免押配置（在支付宝开放平台 -> 我的服务 -> 芝麻信用 -> 租赁服务 中获取）
ZHIMA_SERVICE_ID=your-zhima-service-id          # 芝麻信用服务ID
ZHIMA_CATEGORY=your-zhima-category              # 业务类目编码
DEPOSIT_PRODUCT_MODE=DEPOSIT_ONLY               # 免押模式：DEPOSIT_ONLY/POSTPAY/POSTPAY_UNCERTAIN

# 回调地址（修改为你的实际域名）
NOTIFY_URL=https://your-domain.com/api/orders/notify
RETURN_URL=https://your-domain.com/pay/return
